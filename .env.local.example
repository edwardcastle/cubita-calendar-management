# ─── Supabase ──────────────────────────────────────────────────────────
# Variable names use the legacy convention because @supabase/supabase-js
# and @supabase/ssr default to them. The VALUES below are the new
# publishable/secret keys (sb_publishable_… / sb_secret_…) emitted by
# the current Supabase CLI — both legacy JWT-style keys and the new
# string-prefixed keys are accepted by the SDK.

# Public (browser-safe — embedded in the JS bundle)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (NEVER prefixed with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
